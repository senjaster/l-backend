# Database configuration
DATABASE_URL=postgresql://user:password@localhost:5432/lesiv

# Optional: Override database password separately (useful for secrets management)
# DATABASE_PASSWORD=your_secure_password

# Authentication settings (optional, defaults provided)
# REQUIRE_AUTH=true  # Set to false to disable authentication (for development/testing)
# ACCESS_TOKEN_LIFETIME_MIN=15
# REFRESH_TOKEN_LIFETIME_DAYS=7
# REUSE_LIFETIME_MIN=1
# JWT_ISSUER=l-inspector-backend
# JWT_AUDIENCE=l-inspector-app

# RSA Keys - Option 1: Provide keys directly as environment variables (recommended for production)
# PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...ABCDEF...\n-----END PRIVATE KEY-----"
# PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...ABCDEF...\n-----END PUBLIC KEY-----"

# RSA Keys - Option 2: Provide file paths (fallback if keys not provided directly)
# PRIVATE_KEY_PATH=private.pem
# PUBLIC_KEY_PATH=public.pem